# ============================================================
# SecureGenAI Document Assistant — Environment Variables
# ============================================================
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in values for your environment
#   3. NEVER commit .env to Git (it's in .gitignore)
#
# In production (EKS), these values come from:
#   - Kubernetes ConfigMaps (non-sensitive settings)
#   - Kubernetes Secrets synced from AWS Secrets Manager
#   - IRSA (IAM Roles for Service Accounts) for AWS credentials
#     → You do NOT set AWS_ACCESS_KEY_ID in production.
#       The pod inherits permissions from its service account.
#
# Prefix: All vars use SECUREGENAI_ prefix to avoid collisions
# with other apps running in the same namespace.
# ============================================================

# ── App Settings ──────────────────────────────────────────
SECUREGENAI_ENVIRONMENT=development
SECUREGENAI_LOG_LEVEL=DEBUG
SECUREGENAI_MAX_UPLOAD_SIZE_MB=10

# ── AWS Settings ──────────────────────────────────────────
SECUREGENAI_AWS_REGION=us-east-1
# NOTE: AWS credentials are NOT set here in production.
# In dev, you can use AWS CLI profiles or these vars:
# AWS_ACCESS_KEY_ID=your-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-here
# AWS_SESSION_TOKEN=your-token-if-using-sts

# ── S3 Settings ───────────────────────────────────────────
SECUREGENAI_S3_BUCKET_NAME=securegenai-documents-dev
SECUREGENAI_S3_PREFIX=uploads/

# ── KMS Settings ──────────────────────────────────────────
SECUREGENAI_KMS_KEY_ID=alias/securegenai-document-key

# ── Bedrock Settings ──────────────────────────────────────
SECUREGENAI_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
SECUREGENAI_BEDROCK_MAX_TOKENS=2048
SECUREGENAI_BEDROCK_TEMPERATURE=0.1

# ── DynamoDB Settings ─────────────────────────────────────
SECUREGENAI_DYNAMODB_TABLE_NAME=securegenai-document-registry-dev
